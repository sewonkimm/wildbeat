# Wild Beat Music Academy - 환경변수 설정
# 이 파일을 .env.local로 복사한 후 값을 채워주세요.
# cp .env.example .env.local

# ─── 카카오맵 API ───────────────────────────────────
# 카카오 개발자 콘솔에서 JavaScript 키 발급
# https://developers.kakao.com/
NEXT_PUBLIC_KAKAO_MAP_API_KEY=

# ─── 사이트 URL ─────────────────────────────────────
# Cloudflare Pages 배포 후 실제 도메인으로 변경
NEXT_PUBLIC_SITE_URL=https://wildbeat.co.kr

# ─── 연락처 정보 ────────────────────────────────────
# 상담 폼 제출 시 알림 수신 이메일
CONTACT_NOTIFICATION_EMAIL=info@wildbeat.co.kr

# ─── Google Analytics (선택) ────────────────────────
# GA4 측정 ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=
